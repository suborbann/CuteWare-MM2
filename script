                    end
                    task.wait(0.15)
                    gun:Activate()
                    task.wait(0.4)
                    if myRoot and originalCFrame then
                        myRoot.CFrame = originalCFrame
                    end
                    shootingMurderer = false
                    isAimingPressed = false
                    CuteWare:Notify({Title = "Success", Content = "Shot fired!", Duration = 3})
                    break
                end
            end
            task.wait()
        end
    end)
