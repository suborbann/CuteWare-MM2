                        else
                            -- Gun gone - go back to voting room every 3 seconds
                            root.CFrame = CFrame.new(13.89, 507.13, 35.83)
                            task.wait(3)
                        end

                    -- INNOCENT: look for GunDrop, else stay in voting room every 3 sec
                    else
                        local droppedGun = findGunDrop()
                        if droppedGun then
                            -- Grab dropped gun
                            root.CFrame = droppedGun.CFrame + Vector3.new(0, 2, 0)
                            task.wait(0.5)
                            -- Go back to voting room
                            root.CFrame = CFrame.new(13.89, 507.13, 35.83)
                            task.wait(0.5)
                            -- Start shooting (now has gun from pickup)
                            local newGun = getPlayerGun()
                            if newGun then
                                local murderer = nil
                                for _, p in ipairs(Players:GetPlayers()) do
                                    if p ~= LocalPlayer and playerRoles[p] == "Murderer" then
                                        if p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                                            local hum = p.Character:FindFirstChildOfClass("Humanoid")
                                            if hum and hum.Health > 0 then
                                                murderer = p.Character
                                                break
                                            end
                                        end
                                    end
                                end
                                -- Shoot until gun gone
                                while xpFarmActive and getPlayerGun() do
                                    character = LocalPlayer.Character
                                    root = character and character:FindFirstChild("HumanoidRootPart")
                                    if not root then break end

                                    if murderer then
                                        local mudRoot = murderer:FindFirstChild("HumanoidRootPart")
                                        local hum = murderer:FindFirstChildOfClass("Humanoid")
                                        if not mudRoot or not hum or hum.Health <= 0 then break end
                                        root.CFrame = mudRoot.CFrame * CFrame.new(0, 0, 2)
                                        local g = getPlayerGun()
                                        if g then
                                            if g.Parent == LocalPlayer.Backpack then g.Parent = character end
                                            g:Activate()
                                        end
                                        task.wait(0.3)
                                    else
                                        break
                                    end
                                end
                            end
                        else
                            -- No gun drop - teleport to voting room every 3 seconds
                            root.CFrame = CFrame.new(13.89, 507.13, 35.83)
                            task.wait(3)
                        end
                    end

                    task.wait(0.1)
                end

                -- Disable anti-fling when farm stops
                antiFlingEnabled = false
                CuteWare:Notify({Title = "XP Farm", Content = "XP Autofarm Stopped. Anti-Fling OFF", Duration = 3})
            end)

            -- XP label update loop
            task.spawn(function()
                while xpFarmActive and _G.CuteWareScriptID == currentScriptID do
                    local xpText = getXPLabelData()
                    local xpData = parseXPText(xpText)
                    if xpData then
                        local currentXP = xpData.current
                        local maxXP = xpData.max
                        local earned = currentXP - xpStartValue
                        if earned < 0 then earned = 0 end -- leveled up
                        local remaining = maxXP - currentXP
                        updateLabelText(xpEarnedLabel, "✨ XP Earned : " .. tostring(earned))
                        updateLabelText(xpRemainingLabel, "📊 XP to Next Level : " .. tostring(remaining))
                    end
                    task.wait(1)
                end
            end)

        else
            antiFlingEnabled = false
            CuteWare:Notify({Title = "XP Farm", Content = "XP Autofarm Stopped", Duration = 2})
        end
    end,
})

xpEarnedLabel = XPAutofarmSection:CreateLabel("✨ XP Earned : 0")
xpRemainingLabel = XPAutofarmSection:CreateLabel("📊 XP to Next Level : ---")
