local function toggleElementVisible(element, bool)
    if not element then return end
    if type(element) == "table" then
        for _, k in ipairs({"Instance", "Frame", "Object", "Main", "Container", "Root"}) do
            if element[k] and typeof(element[k]) == "Instance" and element[k]:IsA("GuiObject") then
                element[k].Visible = bool
                return
            end
        end
        for _, v in pairs(element) do
            if typeof(v) == "Instance" and v:IsA("GuiObject") then
                v.Visible = bool
                return
            end
        end
    elseif typeof(element) == "Instance" and element:IsA("GuiObject") then
        element.Visible = bool
    end
end

local function updateLabelText(labelObj, newText)
    if not labelObj then return end
    if type(labelObj) == "table" then
        if labelObj.SetText then
            pcall(function() labelObj:SetText(newText) end)
        elseif labelObj.Text then
            labelObj.Text = newText
        elseif labelObj.Instance and labelObj.Instance:IsA("TextLabel") then
            labelObj.Instance.Text = newText
        elseif labelObj.Label and labelObj.Label:IsA("TextLabel") then
            labelObj.Label.Text = newText
        end
    elseif typeof(labelObj) == "Instance" and labelObj:IsA("TextLabel") then
        labelObj.Text = newText
    end
end

local function getPlayerRole(player)
    local character = player.Character
    local backpack = player:FindFirstChild("Backpack")

    local function checkContainer(container)
        if not container then return nil end
        for _, item in ipairs(container:GetChildren()) do
            if item:IsA("Tool") then
                local name = string.lower(item.Name)
                if name == "knife" or item:FindFirstChild("KnifeScript") or item:FindFirstChild("Stab") or item:FindFirstChild("Slash") then
                    return "Murderer"
                elseif name == "gun" or item:FindFirstChild("GunScript") or item:FindFirstChild("Shoot") or item:FindFirstChild("Activation") then
                    return "Sheriff"
                end
            end
        end
        return nil
    end

    local charRole = checkContainer(character)
    if charRole then return charRole end
    local bpRole = checkContainer(backpack)
    if bpRole then return bpRole end
    return "Innocent"
end

