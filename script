        if not game_ then return nil end
        local inventory = game_:FindFirstChild("Inventory")
        if not inventory then return nil end
        local main = inventory:FindFirstChild("Main")
        if not main then return nil end
        local weapons = main:FindFirstChild("Weapons")
        if not weapons then return nil end
        local evoMenu = weapons:FindFirstChild("EvoMenu")
        if not evoMenu then return nil end
        local container = evoMenu:FindFirstChild("Container")
        if not container then return nil end
        local xpFrame = container:FindFirstChild("XPFrame")
        if not xpFrame then return nil end
        local xpLabel = xpFrame:FindFirstChild("XPLabel")
        if not xpLabel then return nil end
        return xpLabel.Text
    end)
    if success then return result end
    return nil
end

-- Parse XP text like "16,540 / 36,000 XP" -> {current=16540, max=36000}
local function parseXPText(text)
    if not text then return nil end
    local clean = text:gsub(",", ""):gsub(" XP", ""):gsub("XP", "")
    local current, max = clean:match("(%d+)%s*/%s*(%d+)")
    if current and max then
        return {current = tonumber(current), max = tonumber(max)}
    end
    return nil
end

