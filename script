                isAimingPressed = false
                if myRoot and originalCFrame then myRoot.CFrame = originalCFrame end
                CuteWare:Notify({Title = "Finished", Content = "Murderer dead or not found", Duration = 3})
                break
            end

            myChar = LocalPlayer.Character
            myRoot = myChar and myChar:FindFirstChild("HumanoidRootPart")
            local mudRoot = murderer:FindFirstChild("HumanoidRootPart")

            if myRoot and mudRoot then
                local targetPos = mudRoot.Position - (mudRoot.CFrame.LookVector * 2.5)
