local function doFling(targetsTable)
    local Character = LocalPlayer.Character
    local Humanoid = Character and Character:FindFirstChildOfClass("Humanoid")
    local RootPart = Humanoid and Humanoid.RootPart
    if not RootPart or isFlinging then return end

    isFlinging = true
    local OldPos = RootPart.CFrame
    local FPDH = Workspace.FallenPartsDestroyHeight
    Workspace.FallenPartsDestroyHeight = 0/0

    local BV = Instance.new("BodyVelocity")
    BV.Parent = RootPart
    BV.Velocity = Vector3.new(0, 0, 0)
    BV.MaxForce = Vector3.new(9e9, 9e9, 9e9)
    Humanoid:SetStateEnabled(Enum.HumanoidStateType.Seated, false)

    local noclipLoop = RunService.Stepped:Connect(function()
        if Character then
            for _, part in ipairs(Character:GetDescendants()) do
                if part:IsA("BasePart") then part.CanCollide = false end
            end
        end
    end)

    local FPos = function(BasePart, Pos, Ang)
        if not RootPart or not Character then return end
        RootPart.CFrame = CFrame.new(BasePart.Position) * Pos * Ang
        Character:SetPrimaryPartCFrame(CFrame.new(BasePart.Position) * Pos * Ang)
        RootPart.Velocity = Vector3.new(9e7, 9e7 * 10, 9e7)
        RootPart.RotVelocity = Vector3.new(9e8, 9e8, 9e8)
    end

    local SFBasePart = function(BasePart, THumanoid)
        local TimeToWait = 2
        local Time = tick()
        local Angle = 0
        repeat
            if RootPart and THumanoid and BasePart and BasePart.Parent then
                if BasePart.Velocity.Magnitude < 50 then
                    Angle = Angle + 100
                    FPos(BasePart, CFrame.new(0, 1.5, 0) + THumanoid.MoveDirection * BasePart.Velocity.Magnitude / 1.25, CFrame.Angles(math.rad(Angle), 0, 0))
                    task.wait()
                    FPos(BasePart, CFrame.new(0, -1.5, 0) + THumanoid.MoveDirection * BasePart.Velocity.Magnitude / 1.25, CFrame.Angles(math.rad(Angle), 0, 0))
                    task.wait()
                else
                    FPos(BasePart, CFrame.new(0, 1.5, THumanoid.WalkSpeed), CFrame.Angles(math.rad(90), 0, 0))
                    task.wait()
                    FPos(BasePart, CFrame.new(0, -1.5, -THumanoid.WalkSpeed), CFrame.Angles(0, 0, 0))
                    task.wait()
                end
            else
                break
            end
        until tick() - Time > TimeToWait or not isFlinging
    end

    for _, targetName in ipairs(targetsTable) do
        if not isFlinging then break end
        local targetPlayer = Players:FindFirstChild(targetName)
        local TCharacter = targetPlayer and targetPlayer.Character
        local THumanoid = TCharacter and TCharacter:FindFirstChildOfClass("Humanoid")
        local TRootPart = THumanoid and THumanoid.RootPart
        if THumanoid and TRootPart and not THumanoid.Sit then
            Workspace.CurrentCamera.CameraSubject = TRootPart
            SFBasePart(TRootPart, THumanoid)
            task.wait(0.1)
        end
    end

    noclipLoop:Disconnect()
    if BV then BV:Destroy() end
    if Humanoid then
        Humanoid:SetStateEnabled(Enum.HumanoidStateType.Seated, true)
        Workspace.CurrentCamera.CameraSubject = Humanoid
    end

    if RootPart and Character then
        local startTime = tick()
        repeat
            RootPart.CFrame = OldPos * CFrame.new(0, .5, 0)
            Character:SetPrimaryPartCFrame(OldPos * CFrame.new(0, .5, 0))
            if Humanoid then Humanoid:ChangeState("GettingUp") end
            for _, part in pairs(Character:GetChildren()) do
                if part:IsA("BasePart") then
                    part.Velocity, part.RotVelocity = Vector3.new(), Vector3.new()
                end
            end
            task.wait()
        until (RootPart.Position - OldPos.Position).Magnitude < 25 or (tick() - startTime > 2)
    end
    Workspace.FallenPartsDestroyHeight = FPDH
    isFlinging = false
end

-- FIX: Kill Everyone - checks who is still alive (not in lobby), retries if someone survived
local function toggleKillEveryone()
    if killingEveryone then
        killingEveryone = false
        CuteWare:Notify({Title = "Status", Content = "Kill Everyone Stopped", Duration = 2})
        return
    end

    local knife = getPlayerKnife()
    if not knife then
        CuteWare:Notify({Title = "Error", Content = "You must have a knife!", Duration = 3})
        return
    end

    killingEveryone = true
    CuteWare:Notify({Title = "Status", Content = "Kill Everyone Started!", Duration = 2})

    task.spawn(function()
        while killingEveryone do
            if _G.CuteWareScriptID ~= currentScriptID then break end

            knife = getPlayerKnife()
            if not knife then
                killingEveryone = false
                CuteWare:Notify({Title = "Aborted", Content = "Knife lost!", Duration = 3})
                break
            end

            -- Collect all alive players NOT in lobby radius
            local targets = {}
            for _, p in ipairs(Players:GetPlayers()) do
                if p ~= LocalPlayer then
                    local char = p.Character
                    local root = char and char:FindFirstChild("HumanoidRootPart")
                    local hum = char and char:FindFirstChildOfClass("Humanoid")
                    if root and hum and hum.Health > 0 then
                        if not isInLobby(root.Position) then
                            table.insert(targets, p)
                        end
                    end
                end
            end

            if #targets == 0 then
                killingEveryone = false
                CuteWare:Notify({Title = "Finished", Content = "All players killed!", Duration = 3})
                break
            end

            for _, p in ipairs(targets) do
                if not killingEveryone or _G.CuteWareScriptID ~= currentScriptID then break end

                knife = getPlayerKnife()
                if not knife then
                    killingEveryone = false
                    CuteWare:Notify({Title = "Aborted", Content = "Knife disappeared!", Duration = 3})
                    break
                end

                local char = p.Character
                local root = char and char:FindFirstChild("HumanoidRootPart")
                local hum = char and char:FindFirstChildOfClass("Humanoid")

                if root and hum and hum.Health > 0 and not isInLobby(root.Position) then
                    local myChar = LocalPlayer.Character
                    local myRoot = myChar and myChar:FindFirstChild("HumanoidRootPart")

                    if myRoot then
                        myRoot.CFrame = root.CFrame * CFrame.new(0, 0, 0.8)
                        if knife.Parent == LocalPlayer.Backpack then
                            knife.Parent = myChar
                        end
                        for i = 1, 4 do
                            knife:Activate()
                            task.wait(0.02)
                        end
                    end
                    task.wait(0.05)
                end
            end

            -- After going through all targets, loop again to check survivors
            task.wait(0.2)
        end
    end)
end

local function toggleShootMurderer()
