-- Coin farm: fly-style noclip movement toward CoinVisual parts, approach from below
local CoinAutofarmToggle = CoinAutofarmSection:CreateToggle({
    Name = "Start Coin Autofarm",
    Flag = "Start_Coin_Autofarm",
    CurrentValue = false,
    Callback = function(state)
        coinFarmActive = state
        if state then
            CuteWare:Notify({Title = "Coin Farm", Content = "Coin Autofarm Started!", Duration = 2})

            task.spawn(function()
                while coinFarmActive and _G.CuteWareScriptID == currentScriptID do
                    local character = LocalPlayer.Character
                    local root = character and character:FindFirstChild("HumanoidRootPart")
                    local humanoid = character and character:FindFirstChildOfClass("Humanoid")

                    if not root or not humanoid then task.wait(0.5) continue end

                    -- Find nearest visible CoinVisual
                    local nearestCoin = nil
                    local nearestDist = math.huge

                    for _, child in ipairs(Workspace:GetDescendants()) do
                        if child.Name == "CoinVisual" and child:IsA("BasePart") and child.Transparency < 0.9 then
                            local dist = (child.Position - root.Position).Magnitude
                            if dist < nearestDist then
                                nearestDist = dist
                                nearestCoin = child
                            end
                        end
                    end

                    if nearestCoin then
                        -- Enable platformstand for fly-like movement
                        humanoid.PlatformStand = true

                        -- Disable collisions (noclip style)
                        for _, part in ipairs(character:GetDescendants()) do
                            if part:IsA("BasePart") then part.CanCollide = false end
                        end

                        -- Approach from BELOW: go under coin first, then up
                        local coinPos = nearestCoin.Position
                        local belowCoin = Vector3.new(coinPos.X, coinPos.Y - 5, coinPos.Z)

                        -- Move toward below-coin position
                        local startPos = root.Position
                        local steps = math.max(5, math.floor(nearestDist / coinFarmSpeed))

                        for i = 1, steps do
                            if not coinFarmActive then break end
                            character = LocalPlayer.Character
                            root = character and character:FindFirstChild("HumanoidRootPart")
                            if not root then break end

                            -- Check if coin still exists
                            if not nearestCoin or not nearestCoin.Parent or nearestCoin.Transparency >= 0.9 then break end

                            local t = i / steps
                            local targetPos

                            if i <= steps * 0.6 then
                                -- Go to below position first
                                targetPos = startPos:Lerp(belowCoin, t / 0.6)
                            else
                                -- Then go up to coin
                                local t2 = (t - 0.6) / 0.4
                                targetPos = belowCoin:Lerp(coinPos + Vector3.new(0, 1, 0), t2)
                            end

                            root.CFrame = CFrame.new(targetPos)
                            task.wait(0.02 / coinFarmSpeed)
                        end

                        -- Final snap to coin
                        if nearestCoin and nearestCoin.Parent and coinFarmActive then
                            root.CFrame = CFrame.new(nearestCoin.Position + Vector3.new(0, 1, 0))
                        end

                        humanoid.PlatformStand = false
                        for _, part in ipairs(character:GetDescendants()) do
                            if part:IsA("BasePart") then part.CanCollide = true end
                        end
                    else
                        -- Check if bag is full (all bags visible as full)
                        -- This is handled by CoinBagContainerScript side
                        -- Here we check the Full label visibility
                        local isBagFull = false
                        local screenGui = LocalPlayer.PlayerGui:FindFirstChild("CoinBags") or LocalPlayer.PlayerGui:FindFirstChild("MainGUI")
                        if screenGui then
                            for _, frame in ipairs(screenGui:GetDescendants()) do
                                if frame.Name == "Full" and frame:IsA("TextLabel") and frame.Visible then
                                    isBagFull = true
                                    break
                                end
                            end
                        end

                        if isBagFull then
                            CuteWare:Notify({Title = "Coin Farm", Content = "Bag full! Executing action...", Duration = 2})
                            if coinFarmWhenDone == "Reset" then
                                LocalPlayer.Character:BreakJoints()
                                LocalPlayer.CharacterAdded:Wait()
                                task.wait(1.5)
                            elseif coinFarmWhenDone == "TP to Lobby" then
                                local root2 = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
                                if root2 then root2.CFrame = CFrame.new(13.82, 504.78, -51.92) end
                            elseif coinFarmWhenDone == "Kill Everyone" then
                                -- Fling all non-lobby players
                                local targets = {}
                                for _, p in ipairs(Players:GetPlayers()) do
                                    if p ~= LocalPlayer then
                                        local pRoot = p.Character and p.Character:FindFirstChild("HumanoidRootPart")
                                        if pRoot and not isInLobby(pRoot.Position) then
                                            table.insert(targets, p.Name)
                                        end
                                    end
                                end
                                if #targets > 0 then doFling(targets) end
                            end
                        else
                            task.wait(0.5)
                        end
                    end

                    task.wait(0.05)
                end

                -- Cleanup after farm stops
                local character = LocalPlayer.Character
                local humanoid = character and character:FindFirstChildOfClass("Humanoid")
                if humanoid then humanoid.PlatformStand = false end
                if character then
                    for _, part in ipairs(character:GetDescendants()) do
                        if part:IsA("BasePart") then part.CanCollide = true end
                    end
                end
            end)
        else
            CuteWare:Notify({Title = "Coin Farm", Content = "Coin Autofarm Stopped", Duration = 2})
        end
    end,
})

