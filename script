                local targetCFrame = CFrame.lookAt(camera.CFrame.Position, target.Position)
                if aimbotSmoothness == 0 then
                    camera.CFrame = targetCFrame
                else
                    camera.CFrame = camera.CFrame:Lerp(targetCFrame, 1 / (aimbotSmoothness + 1))
                end
            elseif lockingMode == "Cursor" then
                LocalPlayer.CameraMode = Enum.CameraMode.Classic
                local screenPos, onScreen = camera:WorldToViewportPoint(target.Position)
                if onScreen then
                    local mousePos = UserInputService:GetMouseLocation()
                    local deltaX = (screenPos.X - mousePos.X)
                    local deltaY = (screenPos.Y - mousePos.Y)
                    if mousemoverel then
                        local smooth = math.max(1, aimbotSmoothness * 2)
                        mousemoverel(deltaX / smooth, deltaY / smooth)
                    else
                        camera.CFrame = camera.CFrame:Lerp(CFrame.lookAt(camera.CFrame.Position, target.Position), 1 / (aimbotSmoothness + 5))
                    end
                end
            end
        else
            LocalPlayer.CameraMode = Enum.CameraMode.Classic
        end
    else
        if wasAimingActive then
            wasAimingActive = false
            LocalPlayer.CameraMode = Enum.CameraMode.Classic
