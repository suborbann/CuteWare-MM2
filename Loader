local function applyXRay(v)
    if v:IsA("BasePart") and not originalTransparencies[v] then
        if v.Transparency>0 then return end
        if v:FindFirstAncestorOfClass("Tool") then return end
        for _,p in ipairs(Players:GetPlayers()) do if p.Character and v:IsDescendantOf(p.Character) then return end end
        originalTransparencies[v]=v.Transparency
        v.Transparency=0.9
    end
end

ToolsSection:CreateToggle({ Name="Toggle XRay", Flag="XRayToggle", CurrentValue=false, Callback=function(s)
    if s then
        for _,v in ipairs(Workspace:GetDescendants()) do applyXRay(v) end
        descendantConnection=Workspace.DescendantAdded:Connect(function(v) applyXRay(v) end)
        regConn(descendantConnection)
    else
        if descendantConnection then descendantConnection:Disconnect() descendantConnection=nil end
        for part,orig in pairs(originalTransparencies) do if part and part.Parent then part.Transparency=orig end end
        table.clear(originalTransparencies)
    end
end })
ToolsSection:CreateToggle({ Name="Toggle Anti Void", Flag="Anti_Void", CurrentValue=false, Callback=function(s) antiVoidEnabled=s end })
ToolsSection:CreateToggle({ Name="Toggle Low GFX", Flag="Low_GFX", CurrentValue=false, Callback=function(s)
    lowGfxEnabled=s
    if s then
        for _,v in ipairs(Workspace:GetDescendants()) do
            if v:IsA("BasePart") and not v:IsA("Terrain") then if not originalGfx[v] then originalGfx[v]={Material=v.Material} end v.Material=Enum.Material.SmoothPlastic
            elseif v:IsA("Decal") or v:IsA("Texture") then if not originalGfx[v] then originalGfx[v]={Transparency=v.Transparency} end v.Transparency=1 end
        end
    else
        for inst,data in pairs(originalGfx) do
            if inst and inst.Parent then if data.Material then inst.Material=data.Material end if data.Transparency then inst.Transparency=data.Transparency end end
        end
        table.clear(originalGfx)
    end
end })

