regConn(RunService.Heartbeat:Connect(function()
    local character = LocalPlayer.Character
    local humanoid  = character and character:FindFirstChildOfClass("Humanoid")

    if humanoid then
        if walkspeedEnabled  then humanoid.WalkSpeed = walkspeedValue end
        if jumppowerEnabled  then humanoid.UseJumpPower=true humanoid.JumpPower=jumppowerValue end
    end

    if antiVoidEnabled and character then
        local root=character:FindFirstChild("HumanoidRootPart")
        if root then
            local limit=(Workspace.FallenPartsDestroyHeight and Workspace.FallenPartsDestroyHeight~=0/0) and (Workspace.FallenPartsDestroyHeight+35) or -80
            if root.Position.Y<limit then root.Velocity=Vector3.new(0,0,0) root.CFrame=CFrame.new(root.Position.X,70,root.Position.Z) end
        end
    end

    if antiFlingEnabled and not isFlinging then
        for _,player in ipairs(Players:GetPlayers()) do
            if player~=LocalPlayer and player.Character then
                local hrp=player.Character:FindFirstChild("HumanoidRootPart")
                if hrp and not hrp.Anchored then
                    hrp.CustomPhysicalProperties=PhysicalProperties.new(0,0,0,0,0)
                    hrp.Velocity=Vector3.new(0,0,0)
                    hrp.RotVelocity=Vector3.new(0,0,0)
                    hrp.CanCollide=false
                end
            end
        end
    end
end))

