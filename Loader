local function findGunDrop()
    for _, desc in ipairs(Workspace:GetDescendants()) do
        if desc:IsA("BasePart") and (desc.Name=="GunDrop" or desc.Name=="Gun_Drop" or (desc.Name=="Gun" and not desc.Parent:IsA("Model") and not desc.Parent:IsA("Backpack"))) then
            return desc
        end
    end
    return nil
end

local function grabDroppedGunAction()
    local gun=findGunDrop()
    if gun and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
        LocalPlayer.Character.HumanoidRootPart.CFrame=gun.CFrame+Vector3.new(0,2,0)
        CuteWare:Notify({Title="Success",Content="Teleported to Dropped Gun!",Duration=2})
    else
        CuteWare:Notify({Title="Error",Content="Gun is not dropped!",Duration=2})
    end
end

