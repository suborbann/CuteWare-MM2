        while killingEveryone do
            if _G.CuteWareScriptID ~= currentScriptID then break end
            knife = getPlayerKnife()
            if not knife then killingEveryone=false CuteWare:Notify({Title="Aborted",Content="Knife lost!",Duration=3}) break end
