local activeTracks     = {}
local currentEmoteName = nil
local isEmotePlaying   = false
local movementConn     = nil

local function getHumanoid()
    local char = LocalPlayer.Character
    if not char then return nil end
    return char:FindFirstChildOfClass("Humanoid")
end

local function stopAllEmotes()
    for _, track in ipairs(activeTracks) do
        pcall(function()
            if track and track.IsPlaying then
                track:Stop(0.1)
            end
        end)
    end
    activeTracks       = {}
    currentEmoteName   = nil
    isEmotePlaying     = false
    if movementConn then
        movementConn:Disconnect()
        movementConn = nil
    end
end

local function startMovementMonitor(emoteName)
    if movementConn then
        movementConn:Disconnect()
        movementConn = nil
    end
    movementConn = RunService.Heartbeat:Connect(function()
        if not isEmotePlaying or currentEmoteName ~= emoteName then
            movementConn:Disconnect()
            movementConn = nil
            return
        end
        local hum = getHumanoid()
        if hum and hum.MoveDirection.Magnitude > 0.1 then
            stopAllEmotes()
        end
    end)
end

local function playEmoteById(emoteName, animId, looped, priority)
    local hum = getHumanoid()
    if not hum then
        warn("Humanoid not found")
        return false
    end

    stopAllEmotes()

    local anim = Instance.new("Animation")
    anim.AnimationId = "rbxassetid://" .. tostring(animId)

    local track
    local ok, err = pcall(function()
        -- Prefer Animator if available
        local animator = hum:FindFirstChildOfClass("Animator")
        if animator then
            track = animator:LoadAnimation(anim)
        else
            track = hum:LoadAnimation(anim)
        end
    end)

    if not ok or not track then
        warn("Failed to load animation " .. emoteName .. ": " .. tostring(err))
        anim:Destroy()
        return false
    end

    track.Priority = priority or Enum.AnimationPriority.Action
    track.Looped   = looped or false

    local playOk, playErr = pcall(function() track:Play(0.15) end)
    if not playOk then
        warn("Failed to play animation " .. emoteName .. ": " .. tostring(playErr))
        anim:Destroy()
        return false
    end

    table.insert(activeTracks, track)
    currentEmoteName = emoteName
    isEmotePlaying   = true

    -- Stop on jump
    local hum2 = getHumanoid()
    if hum2 then
        hum2.Jumping:Connect(function(active)
            if active and isEmotePlaying and currentEmoteName == emoteName then
                stopAllEmotes()
            end
        end)
    end

    -- Auto-stop when non-looped finishes
    if not looped then
        local length = track.Length
        if length and length > 0 then
            task.delay(length + 0.05, function()
                if currentEmoteName == emoteName then
                    stopAllEmotes()
                end
            end)
        end
    end

    startMovementMonitor(emoteName)
    print("Emote started: " .. emoteName .. " (ID: " .. tostring(animId) .. ")")
    return true
end

