                    if cont then
                        for _,tool in ipairs(cont:GetChildren()) do
                            if tool:IsA("Tool") and (tool.Name:lower()=="knife" or tool:FindFirstChild("KnifeScript") or tool:FindFirstChild("Stab") or tool:FindFirstChild("Slash")) then
                                hasKnife=true break
                            end
                        end
                    end
                    if hasKnife then break end
                end
                if hasKnife and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                    local hum=p.Character:FindFirstChildOfClass("Humanoid")
                    if hum and hum.Health>0 then target=p.Character.HumanoidRootPart break end
                end
            end
        end
        if target then
            local camera=Workspace.CurrentCamera
            if cameraModeSetting=="First Person" then
                LocalPlayer.CameraMode=Enum.CameraMode.LockFirstPerson
            else
                LocalPlayer.CameraMode=Enum.CameraMode.Classic
            end
            local tCF=CFrame.lookAt(camera.CFrame.Position, target.Position)
            if aimbotSmoothness==0 then camera.CFrame=tCF
            else camera.CFrame=camera.CFrame:Lerp(tCF, 1/(aimbotSmoothness+1)) end
        else
            LocalPlayer.CameraMode=Enum.CameraMode.Classic
        end
    else
        if wasAimingActive then wasAimingActive=false LocalPlayer.CameraMode=Enum.CameraMode.Classic end
    end
end)

