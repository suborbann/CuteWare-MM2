local function updateLabelText(labelObj, newText)
    if not labelObj then return end
    if type(labelObj) == "table" then
        if labelObj.SetText then pcall(function() labelObj:SetText(newText) end)
        elseif labelObj.Text then labelObj.Text = newText
        elseif labelObj.Instance and labelObj.Instance:IsA("TextLabel") then labelObj.Instance.Text = newText
        elseif labelObj.Label and labelObj.Label:IsA("TextLabel") then labelObj.Label.Text = newText end
    elseif typeof(labelObj) == "Instance" and labelObj:IsA("TextLabel") then
        labelObj.Text = newText
    end
end

local function getPlayerRole(player)
    local function checkContainer(container)
        if not container then return nil end
        for _, item in ipairs(container:GetChildren()) do
            if item:IsA("Tool") then
                local n = string.lower(item.Name)
                if n == "knife" or item:FindFirstChild("KnifeScript") or item:FindFirstChild("Stab") or item:FindFirstChild("Slash") then
                    return "Murderer"
                elseif n == "gun" or item:FindFirstChild("GunScript") or item:FindFirstChild("Shoot") or item:FindFirstChild("Activation") then
                    return "Sheriff"
                end
            end
        end
        return nil
    end
    local r = checkContainer(player.Character) or checkContainer(player:FindFirstChild("Backpack"))
    return r or "Innocent"
end

