local function getPlayerOptions()
    local opts = {}
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LocalPlayer then table.insert(opts, p.Name) end
    end
    table.sort(opts)
    return opts
end

-- We store references to sections so we can rebuild dropdowns inside them
local flingDropdownRef      = nil
local whitelistDropdownRef  = nil
local flingSection          = nil
local whitelistSection      = nil

local rebuildPending = false
local function rebuildPlayerDropdowns()
    if rebuildPending then return end
    rebuildPending = true
    task.delay(0.5, function()
        rebuildPending = false
        local opts = getPlayerOptions()

        -- Rebuild fling dropdown
        if flingDropdownRef and flingDropdownRef.Refresh then
            pcall(function() flingDropdownRef:Refresh(opts) end)
        end
        -- Rebuild whitelist dropdown
        if whitelistDropdownRef and whitelistDropdownRef.Refresh then
            pcall(function() whitelistDropdownRef:Refresh(opts) end)
        end
    end)
end

